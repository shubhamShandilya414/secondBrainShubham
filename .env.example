# Copy this file to `.env` and fill in your local secrets.

# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPOS=owner/repo,owner2/repo2

# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=ABC
JIRA_JQL=project = CUDI ORDER BY updated DESC

# Worker / ngrok
MEERA_TIMEZONE=Asia/Kolkata
MEERA_WORKER_URL=https://stirrupless-somatologically-lainey.ngrok-free.dev
MEERA_WORKER_PORT=8765
